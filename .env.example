# --- Site ---
# Canonical URL (used for metadata, sitemap, robots). Defaults to https://lakshitwasan.dev
NEXT_PUBLIC_SITE_URL=https://lakshitwasan.dev

# --- Contact form email ---
# The form picks a provider in this order: Resend → AWS SES → console log (dev).
# Configure ONE of them in production.

# Where contact messages are delivered.
CONTACT_TO_EMAIL=lakshitwasan31@gmail.com

# Option 1 — Resend (recommended on Vercel; free tier). Get a key at resend.com.
# Tip: sign up with the same Gmail as CONTACT_TO_EMAIL and you can use the default
# "onboarding@resend.dev" sender immediately, no domain verification needed.
RESEND_API_KEY=
# RESEND_FROM="Portfolio <onboarding@resend.dev>"   # override once your domain is verified

# Option 2 — AWS SES (for the AWS deploy). Leave blank if using Resend.
# SES_FROM_EMAIL=            # a verified SES identity
# AWS_REGION=ap-south-1
# AWS creds come from the default provider chain (instance role / access keys).
